{
  "id": null,
  "title": "Task Manager API Dashboard",
  "tags": ["task-manager", "api"],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(http_request_duration_ms_count[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Response Time (ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(http_request_duration_ms_count{status_code=~\"5..\"}[5m])",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "App Uptime",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"task-manager-api\"}",
          "legendFormat": "Up"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Request Duration Over Time",
      "type": "graph",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "P99"
        }
      ]
    }
  ]
}
